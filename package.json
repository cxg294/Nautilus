{
  "name": "nautilus",
  "private": true,
  "version": "0.2.0",
  "description": "Nautilus — 个人万用工作台，基于 Vue3 + NaiveUI + Express",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"vite --mode test\" \"nodemon server/index.js\"",
    "dev:client": "vite --mode test",
    "dev:server": "nodemon server/index.js",
    "build": "vite build --mode prod",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "gen-route": "sa gen-route",
    "lint": "oxlint --fix && eslint --fix .",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "cleanup": "sa cleanup",
    "db:migrate": "node -e \"import('./server/db/index.js').then(m => m.runMigrations())\"",
    "db:seed": "node server/db/seed.js",
    "setup": "pnpm install && pnpm run db:migrate",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@alicloud/imageseg20191230": "^4.0.1",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "@better-scroll/core": "2.5.1",
    "@google/genai": "^1.47.0",
    "@iconify/vue": "5.0.0",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@tsparticles/plugin-emitters": "^3.9.1",
    "@tsparticles/preset-confetti": "^3.2.0",
    "@tsparticles/preset-fire": "^3.2.0",
    "@tsparticles/preset-firefly": "^3.2.0",
    "@tsparticles/preset-fireworks": "^3.2.0",
    "@tsparticles/preset-fountain": "^3.2.0",
    "@tsparticles/preset-snow": "^3.2.0",
    "@tsparticles/preset-stars": "^3.2.0",
    "@tsparticles/slim": "^3.9.1",
    "@tsparticles/vue3": "^3.0.1",
    "@vueuse/core": "14.2.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "browser-image-compression": "^2.0.2",
    "clipboard": "2.0.11",
    "cors": "^2.8.5",
    "dayjs": "1.11.19",
    "defu": "6.1.4",
    "dotenv": "^16.5.0",
    "echarts": "6.0.0",
    "express": "^5.1.0",
    "json5": "2.2.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mermaid": "^11.13.0",
    "modern-gif": "^2.0.4",
    "multer": "^2.1.1",
    "naive-ui": "2.44.1",
    "nprogress": "0.2.0",
    "pinia": "3.0.4",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.5.0",
    "vue": "3.5.29",
    "vue-draggable-plus": "0.6.1",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
    "@iconify/json": "2.2.447",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config-vue": "^0.0.2",
    "@types/node": "25.3.5",
    "@types/nprogress": "0.2.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "concurrently": "^9.1.2",
    "consola": "3.4.2",
    "eslint": "10.0.3",
    "kolorist": "1.8.0",
    "nodemon": "^3.1.10",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sass": "1.97.3",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "^66.6.6",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "31.0.0",
    "vite": "7.3.1",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "8.0.7",
    "vite-plugin-vue-transition-root-validator": "^0.1.0",
    "vue-tsc": "3.2.5"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm sa git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint && pnpm fmt && git diff --exit-code"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tsparticles/engine",
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp",
      "simple-git-hooks",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}

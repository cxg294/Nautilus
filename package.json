{
  "name": "nautilus",
  "private": true,
  "version": "0.1.0",
  "description": "Nautilus — 个人万用工作台",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"vite\" \"nodemon server/index.js\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "node -e \"import('./server/db/index.js').then(m => m.runMigrations())\"",
    "db:seed": "node server/db/seed.js",
    "setup": "npm install && npm run db:migrate",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "pinia": "^3.0.3",
    "vite": "^8.0.1",
    "vue-router": "^4.5.1"
  }
}

# Nautilus 环境变量模板
# 复制此文件为 .env 并填入实际值

# 服务端口
PORT=3000

# JWT 密钥（生产环境务必更换为随机字符串）
JWT_SECRET=nautilus-dev-secret-change-me
JWT_REFRESH_SECRET=nautilus-dev-refresh-secret-change-me

# JWT 过期时间
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 数据库路径（相对于 server 目录）
DB_PATH=./db/nautilus.db

# 运行环境
NODE_ENV=development

# 阿里云视觉智能开发平台（用于抠图等服务）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
